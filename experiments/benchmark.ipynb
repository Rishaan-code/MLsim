   "source": [
    "# mlsim — Hardware Benchmark (T4)\n",
    "\n",
    "This notebook measures real matmul runtimes across dtypes and matrix sizes on a Colab T4 GPU.\n",
    "The results are used to calibrate the cycle-approximate simulator's quantization crossover model.\n",
    "\n",
    "**Runtime:** ~10-15 minutes on a free T4.\n",
    "\n",
    "**Output:** `results.csv` — download this and add it to the `results/` folder in the repo."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import time\n",
    "import csv\n",
    "import os\n",
    "import itertools\n",
    "from pathlib import Path\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Device: {device}')\n",
    "if torch.cuda.is_available():\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "    print(f'Memory: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Benchmark config\n",
    "# Square matmul sizes — chosen to span the roofline transition region\n",
    "SIZES   = [32, 64, 128, 256, 512, 1024, 2048, 4096]\n",
    "DTYPES  = {\n",
    "    'fp32':  torch.float32,\n",
    "    'fp16':  torch.float16,\n",
    "    'bf16':  torch.bfloat16,\n",
    "    'int8':  None,   # handled separately via torch._int_mm\n",
    "}\n",
    "WARMUP_ITERS  = 20\n",
    "BENCH_ITERS   = 100\n",
    "BATCH_SIZE    = 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def bench_matmul_fp(size, dtype, warmup=20, iters=100):\n",
    "    \"\"\"Benchmark fp32/fp16/bf16 matmul.\"\"\"\n",
    "    A = torch.randn(size, size, dtype=dtype, device=device)\n",
    "    B = torch.randn(size, size, dtype=dtype, device=device)\n",
    "\n",
    "    # Warmup\n",
    "    for _ in range(warmup):\n",
    "        C = torch.mm(A, B)\n",
    "    torch.cuda.synchronize()\n",
    "\n",
    "    # Benchmark\n",
    "    start = torch.cuda.Event(enable_timing=True)\n",
    "    end   = torch.cuda.Event(enable_timing=True)\n",
    "    start.record()\n",
    "    for _ in range(iters):\n",
    "        C = torch.mm(A, B)\n",
    "    end.record()\n",
    "    torch.cuda.synchronize()\n",
    "\n",
    "    elapsed_ms = start.elapsed_time(end) / iters\n",
    "    flops      = 2 * size * size * size\n",
    "    tflops     = flops / (elapsed_ms * 1e-3) / 1e12\n",
    "    return elapsed_ms, tflops\n",
    "\n",
    "\n",
    "def bench_matmul_int8(size, warmup=20, iters=100):\n",
    "    \"\"\"Benchmark int8 matmul using torch._int_mm.\"\"\"\n",
    "    A = torch.randint(-128, 127, (size, size), dtype=torch.int8, device=device)\n",
    "    B = torch.randint(-128, 127, (size, size), dtype=torch.int8, device=device)\n",
    "\n",
    "    try:\n",
    "        for _ in range(warmup):\n",
    "            C = torch._int_mm(A, B)\n",
    "        torch.cuda.synchronize()\n",
    "\n",
    "        start = torch.cuda.Event(enable_timing=True)\n",
    "        end   = torch.cuda.Event(enable_timing=True)\n",
    "        start.record()\n",
    "        for _ in range(iters):\n",
    "            C = torch._int_mm(A, B)\n",
    "        end.record()\n",
    "        torch.cuda.synchronize()\n",
    "\n",
    "        elapsed_ms = start.elapsed_time(end) / iters\n",
    "        flops      = 2 * size * size * size\n",
    "        tflops     = flops / (elapsed_ms * 1e-3) / 1e12\n",
    "        return elapsed_ms, tflops\n",
    "    except Exception as e:\n",
    "        print(f'  int8 skipped at size {size}: {e}')\n",
    "        return None, None\n",
    "\n",
    "\n",
    "def arithmetic_intensity(size, dtype_bytes):\n",
    "    flops  = 2 * size * size * size\n",
    "    nbytes = dtype_bytes * (3 * size * size)   # A + B + C\n",
    "    return flops / nbytes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DTYPE_BYTES = {'fp32': 4, 'fp16': 2, 'bf16': 2, 'int8': 1}\n",
    "\n",
    "rows = []\n",
    "\n",
    "for size in SIZES:\n",
    "    print(f'\\nSize {size}x{size}x{size}')\n",
    "\n",
    "    for dtype_name, torch_dtype in DTYPES.items():\n",
    "        if dtype_name == 'int8':\n",
    "            elapsed_ms, tflops = bench_matmul_int8(size, WARMUP_ITERS, BENCH_ITERS)\n",
    "        else:\n",
    "            elapsed_ms, tflops = bench_matmul_fp(size, torch_dtype, WARMUP_ITERS, BENCH_ITERS)\n",
    "\n",
    "        if elapsed_ms is None:\n",
    "            continue\n",
    "\n",
    "        ai = arithmetic_intensity(size, DTYPE_BYTES[dtype_name])\n",
    "\n",
    "        print(f'  {dtype_name:5s}  {elapsed_ms:.4f} ms   {tflops:.3f} TFLOPS   AI={ai:.1f}')\n",
    "\n",
    "        rows.append({\n",
    "            'hardware':             'GPU (T4)',\n",
    "            'workload':             f'MatMul {size}x{size}x{size}',\n",
    "            'matrix_size':          size,\n",
    "            'dtype':                dtype_name,\n",
    "            'runtime_ms':           round(elapsed_ms, 6),\n",
    "            'tflops':               round(tflops, 4),\n",
    "            'arithmetic_intensity': round(ai, 2),\n",
    "            'flops':                2 * size * size * size,\n",
    "            'bytes_accessed':       DTYPE_BYTES[dtype_name] * 3 * size * size,\n",
    "        })\n",
    "\n",
    "print('\\nDone.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Also capture GPU properties for the paper\n",
    "gpu_info = {\n",
    "    'name':        torch.cuda.get_device_name(0),\n",
    "    'memory_gb':   torch.cuda.get_device_properties(0).total_memory / 1e9,\n",
    "    'sm_count':    torch.cuda.get_device_properties(0).multi_processor_count,\n",
    "    'cuda_version':torch.version.cuda,\n",
    "    'torch_version':torch.__version__,\n",
    "}\n",
    "print('GPU info:')\n",
    "for k, v in gpu_info.items():\n",
    "    print(f'  {k}: {v}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Quick visualization before saving\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "dtype_colors = {'fp32': '#2D6BE4', 'fp16': '#27AE60', 'bf16': '#F39C12', 'int8': '#E84545'}\n",
    "\n",
    "# Runtime vs matrix size\n",
    "for dtype_name in ['fp32', 'fp16', 'bf16', 'int8']:\n",
    "    subset = [r for r in rows if r['dtype'] == dtype_name]\n",
    "    if not subset:\n",
    "        continue\n",
    "    sizes_  = [r['matrix_size']  for r in subset]\n",
    "    times_  = [r['runtime_ms']   for r in subset]\n",
    "    ax1.plot(sizes_, times_, marker='o', label=dtype_name,\n",
    "             color=dtype_colors[dtype_name], linewidth=2)\n",
    "\n",
    "ax1.set_xlabel('Matrix size (N)')\n",
    "ax1.set_ylabel('Runtime (ms)')\n",
    "ax1.set_title('Runtime vs matrix size')\n",
    "ax1.set_yscale('log')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# TFLOPS vs arithmetic intensity (mini roofline)\n",
    "for dtype_name in ['fp32', 'fp16', 'bf16', 'int8']:\n",
    "    subset = [r for r in rows if r['dtype'] == dtype_name]\n",
    "    if not subset:\n",
    "        continue\n",
    "    ais_    = [r['arithmetic_intensity'] for r in subset]\n",
    "    tflops_ = [r['tflops']              for r in subset]\n",
    "    ax2.scatter(ais_, tflops_, label=dtype_name,\n",
    "                color=dtype_colors[dtype_name], s=60, zorder=4)\n",
    "    ax2.plot(ais_, tflops_, color=dtype_colors[dtype_name],\n",
    "             linewidth=1.5, alpha=0.6)\n",
    "\n",
    "ax2.set_xlabel('Arithmetic intensity (FLOPs/byte)')\n",
    "ax2.set_ylabel('Achieved TFLOPS')\n",
    "ax2.set_title('Achieved TFLOPS vs arithmetic intensity')\n",
    "ax2.set_xscale('log')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle(f'T4 Benchmark Results', fontsize=13, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('benchmark_preview.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Preview saved.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save CSV\n",
    "out_path = 'results.csv'\n",
    "fieldnames = ['hardware', 'workload', 'matrix_size', 'dtype',\n",
    "              'runtime_ms', 'tflops', 'arithmetic_intensity',\n",
    "              'flops', 'bytes_accessed']\n",
    "\n",
    "with open(out_path, 'w', newline='') as f:\n",
    "    writer = csv.DictWriter(f, fieldnames=fieldnames)\n",
    "    writer.writeheader()\n",
    "    writer.writerows(rows)\n",
    "\n",
    "print(f'Saved {len(rows)} rows to {out_path}')\n",
    "print('Download this file and add it to the results/ folder in the repo.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Download helper\n",
    "from google.colab import files\n",
    "files.download('results.csv')\n",
    "files.download('benchmark_preview.png')"
   ]
  }
 ]
}"
